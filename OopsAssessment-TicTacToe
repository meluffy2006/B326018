using namespace std;

// ==================== Abstract Base Class ====================
// Demonstrates Abstraction and Polymorphism
class Player {
protected:
    char symbol;
    string name;

public:
    Player(char sym, string n) : symbol(sym), name(n) {}
    
    virtual ~Player() {}
    
    char getSymbol() const { return symbol; }
    string getName() const { return name; }
    
    // Pure virtual function - enforces derived classes to implement
    virtual int makeMove(const vector<vector<char>>& board) = 0;
};

// ==================== Human Player Class ====================
// Inherits from Player - demonstrates Inheritance
class HumanPlayer : public Player {
public:
    HumanPlayer(char sym, string n) : Player(sym, n) {}
    
    // Override pure virtual function
    int makeMove(const vector<vector<char>>& board) override {
        int position;
        bool validMove = false;
        
        while (!validMove) {
            cout << "\n" << name << " (" << symbol << "), enter position (1-9): ";
            cin >> position;
            
            if (position < 1 || position > 9) {
                cout << "Invalid position! Choose between 1-9.";
                continue;
            }
            
            int row = (position - 1) / 3;
            int col = (position - 1) % 3;
            
            if (board[row][col] != ' ') {
                cout << "Position already occupied! Choose another.";
                continue;
            }
            
            validMove = true;
        }
        
        return position;
    }
};

// ==================== AI Player Class ====================
// Inherits from Player - demonstrates Inheritance and Polymorphism
class AIPlayer : public Player {
public:
    AIPlayer(char sym, string n) : Player(sym, n) {}
    
    // Override pure virtual function with AI logic
    int makeMove(const vector<vector<char>>& board) override {
        int bestMove = findBestMove(board);
        cout << "\n" << name << " (" << symbol << ") chooses position " << bestMove << endl;
        return bestMove;
    }
    
private:
    // Minimax Algorithm for AI
    int minimax(vector<vector<char>> board, int depth, bool isMaximizing) {
        char result = checkWinner(board);
        
        // Base cases
        if (result == symbol) return 10 - depth;        // AI wins
        if (result == 'O' || result == 'X') return depth - 10; // Opponent wins
        if (result == 'D') return 0;                     // Draw
        
        if (isMaximizing) {
            int bestScore = INT_MIN;
            for (int i = 0; i < 3; i++) {
                for (int j = 0; j < 3; j++) {
                    if (board[i][j] == ' ') {
                        board[i][j] = symbol;
                        int score = minimax(board, depth + 1, false);
                        board[i][j] = ' ';
                        bestScore = max(bestScore, score);
                    }
                }
            }
            return bestScore;
        } else {
            int bestScore = INT_MAX;
            char opponent = (symbol == 'X') ? 'O' : 'X';
            for (int i = 0; i < 3; i++) {
                for (int j = 0; j < 3; j++) {
                    if (board[i][j] == ' ') {
                        board[i][j] = opponent;
                        int score = minimax(board, depth + 1, true);
                        board[i][j] = ' ';
                        bestScore = min(bestScore, score);
                    }
                }
            }
            return bestScore;
        }
    }
    
    int findBestMove(const vector<vector<char>>& board) {
        int bestScore = INT_MIN;
        int bestMove = -1;
        
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (board[i][j] == ' ') {
                    vector<vector<char>> tempBoard = board;
                    tempBoard[i][j] = symbol;
                    int score = minimax(tempBoard, 0, false);
                    
                    if (score > bestScore) {
                        bestScore = score;
                        bestMove = i * 3 + j + 1;
                    }
                }
            }
        }
        return bestMove;
    }
    
    char checkWinner(const vector<vector<char>>& board) {
        // Check rows
        for (int i = 0; i < 3; i++) {
            if (board[i][0] == board[i][1] && board[i][1] == board[i][2] && board[i][0] != ' ')
                return board[i][0];
        }
        
        // Check columns
        for (int i = 0; i < 3; i++) {
            if (board[0][i] == board[1][i] && board[1][i] == board[2][i] && board[0][i] != ' ')
                return board[0][i];
        }
        
        // Check diagonals
        if (board[0][0] == board[1][1] && board[1][1] == board[2][2] && board[0][0] != ' ')
            return board[0][0];
        if (board[0][2] == board[1][1] && board[1][1] == board[2][0] && board[0][2] != ' ')
            return board[0][2];
        
        // Check draw
        bool isFull = true;
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (board[i][j] == ' ') isFull = false;
            }
        }
        if (isFull) return 'D';
        
        return ' ';
    }
};

// ==================== Game Board Class ====================
// Demonstrates Encapsulation
class Board {
private:
    vector<vector<char>> grid;
    
public:
    // Constructor - demonstrates initialization
    Board() {
        grid.resize(3, vector<char>(3, ' '));
    }
    
    // Display the board
    void display() const {
        cout << "\n";
        cout << "     1   2   3\n";
        cout << "   +---+---+---+\n";
        for (int i = 0; i < 3; i++) {
            cout << " " << (i + 1) << " | " << grid[i][0] << " | " << grid[i][1] << " | " << grid[i][2] << " |\n";
            cout << "   +---+---+---+\n";
        }
        cout << "\n";
    }
    
    // Place a move on the board
    bool placeMove(int position, char symbol) {
        if (position < 1 || position > 9) return false;
        
        int row = (position - 1) / 3;
        int col = (position - 1) % 3;
        
        if (grid[row][col] != ' ') return false;
        
        grid[row][col] = symbol;
        return true;
    }
    
    // Check winner - demonstrates encapsulation
    char checkWinner() const {
        // Check rows
        for (int i = 0; i < 3; i++) {
            if (grid[i][0] == grid[i][1] && grid[i][1] == grid[i][2] && grid[i][0] != ' ')
                return grid[i][0];
        }
        
        // Check columns
        for (int i = 0; i < 3; i++) {
            if (grid[0][i] == grid[1][i] && grid[1][i] == grid[2][i] && grid[0][i] != ' ')
                return grid[0][i];
        }
        
        // Check diagonals
        if (grid[0][0] == grid[1][1] && grid[1][1] == grid[2][2] && grid[0][0] != ' ')
            return grid[0][0];
        if (grid[0][2] == grid[1][1] && grid[1][1] == grid[2][0] && grid[0][2] != ' ')
            return grid[0][2];
        
        return ' ';
    }
    
    // Check if board is full
    bool isFull() const {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (grid[i][j] == ' ') return false;
            }
        }
        return true;
    }
    
    // Reset board
    void reset() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                grid[i][j] = ' ';
            }
        }
    }
    
    // Getter for grid
    const vector<vector<char>>& getGrid() const {
        return grid;
    }
};

// ==================== Game Manager Class ====================
// Demonstrates composition and game control logic
class Game {
private:
    Board board;
    Player* player1;
    Player* player2;
    Player* currentPlayer;
    
public:
    // Constructor
    Game(Player* p1, Player* p2) : player1(p1), player2(p2), currentPlayer(p1) {}
    
    // Destructor - demonstrates proper cleanup
    ~Game() {
        delete player1;
        delete player2;
    }
    
    // Play a single round
    void playRound() {
        board.display();
        
        int move = currentPlayer->makeMove(board.getGrid());
        board.placeMove(move, currentPlayer->getSymbol());
        
        // Switch player
        currentPlayer = (currentPlayer == player1) ? player2 : player1;
    }
    
    // Check game status
    bool isGameOver() {
        char winner = board.checkWinner();
        
        if (winner != ' ') {
            board.display();
            if (winner == 'D') {
                cout << "It's a DRAW!\n";
            } else {
                Player* winnerPlayer = (winner == player1->getSymbol()) ? player1 : player2;
                cout << "🎉 " << winnerPlayer->getName() << " (" << winner << ") WINS! 🎉\n";
            }
            return true;
        }
        
        // Check if board is full (draw condition)
        if (board.isFull()) {
            board.display();
            cout << "It's a DRAW! Board is full.\n";
            return true;
        }
        
        return false;
    }
    
    // Main game loop
    void play() {
        cout << "\n========== TIC TAC TOE ==========\n";
        cout << player1->getName() << " (" << player1->getSymbol() << ") vs "
             << player2->getName() << " (" << player2->getSymbol() << ")\n";
        cout << "================================\n";
        
        while (!isGameOver()) {
            playRound();
        }
    }
    
    // Reset game for replay
    void reset() {
        board.reset();
        currentPlayer = player1;
    }
};

// ==================== Main Function ====================
int main() {
    srand(time(0)); // Seed for random numbers
    
    int gameMode;
    bool playAgain = true;
    
    while (playAgain) {
        cout << "\n========== TIC TAC TOE GAME ==========\n";
        cout << "1. Human vs AI\n";
        cout << "2. Human vs Human\n";
        cout << "3. AI vs AI (Watch them play)\n";
        cout << "Enter your choice (1-3): ";
        cin >> gameMode;
        
        Game* game = nullptr;
        
        switch (gameMode) {
            case 1:
                game = new Game(new HumanPlayer('X', "You"), new AIPlayer('O', "AI"));
                break;
            case 2:
                game = new Game(new HumanPlayer('X', "Player 1"), new HumanPlayer('O', "Player 2"));
                break;
            case 3:
                game = new Game(new AIPlayer('X', "AI-1"), new AIPlayer('O', "AI-2"));
                break;
            default:
                cout << "Invalid choice!\n";
                continue;
        }
        
        game->play();
        
        cout << "\nDo you want to play again? (1 for Yes, 0 for No): ";
        int choice;
        cin >> choice;
        playAgain = (choice == 1);
        
        delete game;
    }
    
    cout << "\nThanks for playing! Goodbye.\n";
    return 0;
}
